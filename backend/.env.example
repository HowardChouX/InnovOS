# InnovOS 后端环境变量配置示例
# 复制为 .env 并填入实际值

# === 必填配置 ===

# 加密密钥（AES-256 Fernet）
# 生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INNOVOS_ENCRYPT_KEY=

# JWT 密钥（用于 Token 签名）
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
INNOVOS_JWT_SECRET=

# === AI 配置 ===

# DeepSeek API Key（兜底，Key 池为空时使用）
DEEPSEEK_API_KEY=

# OpenAI Base URL（可选，默认 https://api.deepseek.com）
# OPENAI_BASE_URL=https://api.deepseek.com

# === 数据库配置 ===

# 数据库路径（生产环境建议 PostgreSQL）
DATABASE_URL=sqlite:///InnovOS_ACCOUNTS.db

# === 服务器配置 ===

# HOST=0.0.0.0
# PORT=8000
# WORKERS=4
# LOG_LEVEL=info

# === CORS 配置 ===

# 允许的前端域名（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
